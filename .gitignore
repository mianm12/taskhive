# 本项目使用拒绝名单模板。若倾向白名单模板，参考社区模板：
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore

# ── 构建与二进制产物 ──
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# ── 测试与覆盖率产物 ──
## go test -c 编译出的测试二进制
*.test
*.out
coverage.*
*.coverprofile
profile.cov

# ── Go 模块与工作区 ──
## 取消下一行注释以忽略 vendor 目录
# vendor/
go.work
go.work.sum

# ── 环境与密钥 ──
.env
.env.*
!.env.example

# ── 编辑器 / IDE ──
# .idea/
.vscode/

# ── macOS ──
## 通用设置
.DS_Store
.AppleDouble
.LSOverride
## 桌面自定义图标文件（名称以回车结尾）
Icon
## 资源分叉（resource fork）
._*
## 卷根目录下可能出现的文件和目录
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
